---
import "../styles/global.css"

const { title = "briheet's site" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
 		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
  </head>

  <body class="bg-zinc-900 text-zinc-400 antialiased flex flex-col">
    <slot />
  </body>
</html>
<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
