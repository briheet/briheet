---
import { getCollection } from "astro:content";
import Footer from "../../components/Footer.astro";
import Nav from "../../components/Nav.astro";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blogs", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat("en", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  }).format(date);
};
---

<Layout title="Blogs | Briheet Singh Yadav">
  <div class="min-h-screen">
    <Nav />

    <main class="mx-auto mt-0 max-w-5xl px-6">
      <section class="divide-y divide-white/10">
        {
          posts.map((post) => (
            <article class="py-7 first:pt-0">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-zinc-500">
                <time datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>

                {post.data.tags?.slice(0, 3).map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>

              <h2 class="mt-3 text-xl font-semibold text-white">
                <a
                  href={`/blogs/${post.id}/`}
                  class="transition-colors duration-300 hover:text-zinc-300"
                >
                  {post.data.title}
                </a>
              </h2>

              <p class="mt-3 text-base leading-7 text-zinc-400">
                {post.data.description}
              </p>
            </article>
          ))
        }
      </section>
    </main>

    <Footer />
  </div>
</Layout>
